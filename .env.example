# Contact form + newsletter (Resend) — https://resend.com
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=info@geoffreyrcrawford.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Optional: Resend Audience for newsletter subscribers.
# When set, /api/subscribe adds contacts to this audience.
# When unset, new subscribers are emailed to your inbox instead (nothing lost).
RESEND_AUDIENCE_ID=

# Google Analytics — https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------------------------------------------------------------------------
# Workspace / accounts (Supabase) — https://supabase.com  [OPTIONAL]
# Leave these blank and the workspace shows a clean "coming soon" state; the
# free Campaign Builder keeps working with no account. Set all three to turn on
# accounts, saved campaign history, and the /app dashboard.
#
# Find them in Supabase → Project Settings → API.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose this to the client / commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: AI-generated campaign plans (falls back to rules if unset).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
